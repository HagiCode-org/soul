{
  "name": "soul",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run prepare:i18n && vite",
    "materials:sync": "node scripts/generate-reference-materials.mjs",
    "build": "npm run prepare:i18n && npm run sync:footer-sites && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run prepare:i18n && vitest run",
    "sync:agent-templates": "node ./scripts/generate-agent-templates.mjs",
    "sync:footer-sites": "node ./scripts/fetch-sites-snapshot.mjs",
    "i18n:audit": "hagi18n audit --config hagi18n.yaml",
    "i18n:report": "hagi18n report --config hagi18n.yaml",
    "i18n:doctor": "hagi18n doctor --config hagi18n.yaml",
    "i18n:sync": "hagi18n sync --config hagi18n.yaml --from en-US",
    "i18n:sync:write": "hagi18n sync --config hagi18n.yaml --from en-US --write",
    "i18n:prune": "hagi18n prune --config hagi18n.yaml --from en-US",
    "i18n:prune:write": "hagi18n prune --config hagi18n.yaml --from en-US --write",
    "i18n:generate": "node scripts/generate-i18n-resources.mjs",
    "prepare:i18n": "npm run i18n:generate",
    "i18n:check": "npm run i18n:audit && npm run i18n:doctor && npm run prepare:i18n && node scripts/generate-i18n-resources.mjs --check && vitest run scripts/__tests__/generate-i18n-resources.test.mjs src/i18n/config.test.ts src/pages/HomePage.test.tsx"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/manrope": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.10.9",
    "lucide-react": "^1.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.5",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hagicode/hagi18n": "^0.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
